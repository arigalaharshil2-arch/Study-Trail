{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for Study Trail application",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:default",
    "dialog:allow-open",
    "dialog:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:default"
  ]
}
